[debug] [2026-04-26T03:16:44.524Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/daominhquanproject20200913/rulesets {"name":"projects/daominhquanproject20200913/rulesets/bf7157d4-745a-45b5-a7c5-40f95e657e33","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isProjectMember(projectId) {\n      return signedIn()\n        && get(/databases/$(database)/documents/projects/$(projectId))\n          .data.memberIds.hasAny([request.auth.uid]);\n    }\n\n    match /projects/{projectId} {\n      allow read: if signedIn()\n        && resource.data.memberIds.hasAny([request.auth.uid]);\n      allow create: if signedIn()\n        && request.resource.data.ownerId == request.auth.uid\n        && request.resource.data.memberIds.hasAny([request.auth.uid]);\n      allow update, delete: if signedIn()\n        && resource.data.memberIds.hasAny([request.auth.uid]);\n\n      match /tasks/{taskId} {\n        allow read, write: if isProjectMember(projectId);\n      }\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-26T03:16:44.229983Z","metadata":{"services":["cloud.firestore"]}}
